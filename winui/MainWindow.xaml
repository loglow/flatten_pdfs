<Window
    x:Class="App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Structure and theme brushes live here; all text, sizes, and spacing
         come from the shared spec, assigned in code-behind. -->
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar x:Name="Menu">
            <MenuBarItem Title="File">
                <MenuFlyoutItem x:Name="OpenItem" Text="Open..." Click="OnOpenClick">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="OnExitClick" />
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem x:Name="AboutItem" Click="OnAboutClick" />
            </MenuBarItem>
        </MenuBar>

        <!-- The drop zone is the content area only (the region the outline
             encloses); the menu above it does not accept drops. The explicit
             Transparent background keeps the whole surface hit-testable for
             drag-and-drop (a null background is not) while letting the Mica
             backdrop show through. -->
        <Grid x:Name="DropZone" Grid.Row="1" Background="Transparent" AllowDrop="True"
              DragOver="OnDragOver" DragLeave="OnDragLeave" Drop="OnDrop">
            <Grid x:Name="ContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />

                <TextBlock x:Name="DetailText" Grid.Row="1"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" />

                <StackPanel x:Name="Buttons" Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="SelectButton" Click="OnOpenClick" />
                    <Button x:Name="ClearButton" Click="OnClearClick" />
                </StackPanel>

                <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <ScrollViewer x:Name="LogScroller"
                                  VerticalScrollBarVisibility="Auto" Padding="8">
                        <TextBlock x:Name="LogText" FontFamily="Consolas"
                                   IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- The accent outline shown while a valid drag is over the
                 drop zone: an overlay, so toggling it never reflows the
                 content beneath. Flush with the window edges; all four
                 corners round equally, concentric with Windows 11's 8px
                 window curvature. The brush is assigned in
                 code from SystemAccentColor (the user's actual accent,
                 matching the other targets) rather than the
                 theme-lightened accent fill token. -->
            <Border x:Name="Outline" CornerRadius="8"
                    IsHitTestVisible="False"
                    BorderThickness="0" />
        </Grid>
    </Grid>
</Window>
