<Application
    x:Class="App.MainApp"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Keep scrollbars visible instead of Fluent's fade-at-rest
                 auto-hide, matching the persistent scrollbars of the mac
                 and winforms targets. -->
            <x:Boolean x:Key="ScrollViewerAutoHideScrollBars">False</x:Boolean>
        </ResourceDictionary>
    </Application.Resources>
</Application>
